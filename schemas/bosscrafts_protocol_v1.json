{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "bosscrafts:protocol:v1:message",
  "title": "BossCrafts Protocol v1 Message",
  "description": "Canonical message envelope for all BossCrafts Protocol v1 messages (events and commands).",
  "type": "object",
  "required": ["protocol_version", "type", "timestamp"],
  "properties": {
    "protocol_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Protocol version string, e.g. '1.0'"
    },
    "type": {
      "type": "string",
      "enum": ["event", "command"],
      "description": "Message type: 'event' or 'command'"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp of when the message was created"
    },
    "source": {
      "type": "string",
      "description": "Agent or system that emitted this message (required for type=event)"
    },
    "target": {
      "type": "string",
      "description": "Target agent identifier (required for type=command)"
    },
    "event": {
      "type": "string",
      "description": "Event name (required for type=event)"
    },
    "command": {
      "type": "string",
      "description": "Command name (required for type=command)"
    },
    "level": {
      "type": "string",
      "enum": ["debug", "info", "warning", "error", "critical"],
      "description": "Log level for event messages (default: info)"
    },
    "data": {
      "type": "object",
      "description": "Arbitrary event data payload (for type=event)"
    },
    "args": {
      "type": "object",
      "description": "Command arguments (for type=command)"
    },
    "issued_by": {
      "type": "string",
      "description": "Identifier of who issued the command (for type=command)"
    }
  },
  "additionalProperties": true
}
