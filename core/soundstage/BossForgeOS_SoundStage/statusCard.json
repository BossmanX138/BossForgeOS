{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "SoundStage Status",
      "weight": "Bolder",
      "size": "Medium"
    },
    {
      "type": "TextBlock",
      "text": "Status: ${status}"
    },
    {
      "type": "TextBlock",
      "text": "Active Programs: ${activePrograms.join(', ')}"
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "$data": "${soundMappings}",
          "title": "${$index}",
          "value": "${$data}"
        }
      ]
    }
  ]
}
